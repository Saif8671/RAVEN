# ─────────────────────────────────────────────────────────────────────────────
# RAVEN — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── SUPERVITY ─────────────────────────────────────────────────────────────────
# Your Supervity workflow ID (from the workflow URL or dashboard)
SUPERVITY_WORKFLOW_ID=your_workflow_id_here

# Your Supervity Bearer token (from Supervity → Settings → API Keys)
SUPERVITY_BEARER_TOKEN=your_bearer_token_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local dev with Vite: http://localhost:5173
# For local dev with Next.js: http://localhost:3000
# For production: https://yourdomain.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# Set to 'production' in Vercel dashboard automatically
NODE_ENV=development
